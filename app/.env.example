# Copy to .env.local and fill in. Only VITE_* vars reach the browser.
# The anon key is safe to expose (RLS protects data). NEVER put the
# service_role key or Resend key here — those live in Supabase secrets only.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
